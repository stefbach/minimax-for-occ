# LiveKit (https://cloud.livekit.io)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# MiniMax — TTS only.
MINIMAX_API_KEY=

# DeepSeek — chat completions, analysis, copilot (https://platform.deepseek.com/api_keys).
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # override for proxy / on-prem

# OpenAI — RAG embeddings only (text-embedding-3-small, 1536 dims).
# Not needed if you don't use the RAG / document-search feature.
OPENAI_API_KEY=

# Supabase — agents, n8n bindings, RAG documents.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# n8n integration (Settings -> API in your n8n instance)
N8N_BASE_URL=https://your-n8n.example.cloud
N8N_API_KEY=
N8N_WEBHOOK_BASE_URL=

# Twilio Voice -> LiveKit SIP bridge (used by /api/twilio-voice)
LIVEKIT_SIP_URI=sip:your-project.sip.livekit.cloud
LIVEKIT_SIP_USERNAME=
LIVEKIT_SIP_PASSWORD=

# Twilio REST API — used by /numbers to search, purchase and release numbers.
# Get these from Twilio Console -> Account -> API keys & tokens.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Auth on /api/token (rate-limit + optional shared bearer)
APP_SHARED_TOKEN=
TOKEN_RATE_LIMIT_PER_MINUTE=20
