# LiveKit (https://cloud.livekit.io)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# MiniMax LLM for /api/chat (https://platform.minimax.io)
MINIMAX_API_KEY=

# n8n integration (Settings -> API in your n8n instance)
N8N_BASE_URL=https://your-n8n.example.cloud
N8N_API_KEY=
N8N_WEBHOOK_BASE_URL=

# Twilio Voice -> LiveKit SIP bridge (used by /api/twilio-voice)
LIVEKIT_SIP_URI=sip:your-project.sip.livekit.cloud
LIVEKIT_SIP_USERNAME=
LIVEKIT_SIP_PASSWORD=

# Auth on /api/token (rate-limit + optional shared bearer)
APP_SHARED_TOKEN=
TOKEN_RATE_LIMIT_PER_MINUTE=20
