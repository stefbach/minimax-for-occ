# Build-time environment variables for the production Next.js build.
#
# NOTE: This file is checked into a public GitHub repository and is used
# intentionally as the deployment mechanism for this project (no Vercel
# Dashboard admin access). GitHub Push Protection may flag API keys here —
# follow the provided override link when it does.
#
# Variables that live here:
#   LIVEKIT_SIP_URI            — SIP address for Twilio → LiveKit bridging
#   LIVEKIT_SIP_OUTBOUND_TRUNK_ID — LiveKit outbound SIP trunk id
#   TWILIO_API_KEY_SID/SECRET  — Twilio Voice SDK tokens (softphone)
#   TWILIO_TWIML_APP_SID       — TwiML app for outbound browser calls
#   DEEPSEEK_API_KEY           — LLM + RAG embeddings (replaces OpenAI)

LIVEKIT_SIP_URI=sip:3kreo1a8e9g.sip.livekit.cloud

# LiveKit outbound trunk for /api/desk/dial — when set, the endpoint dials via
# LiveKit's SIP API (which then sends INVITE to Twilio via this trunk) instead
# of the legacy Twilio REST + TwiML callback path. The answered PSTN leg lands
# directly in the human's `desk-<handle>` LiveKit room, so the softphone user
# actually talks to the destination instead of an auto-dispatched AI persona.
# Trunk created on LiveKit Cloud (project `minimax`) pointing at the
# `axon-mu.pstn.twilio.com` Termination URI of the Twilio Elastic SIP Trunk.
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_kcSYWnBaacaS

# Twilio Voice SDK — pour le softphone navigateur (browser ↔ Twilio ↔ PSTN).
# Utilisé par /api/desk/twilio-token et /api/twilio/voice-outbound.
# Choix explicite de la team de mettre ces valeurs dans le repo plutôt que
# sur Vercel Dashboard (pas d'accès admin pour la personne qui les gère).
# Si GitHub Push Protection bloque, suivre le lien d'override qu'il fournit.
TWILIO_API_KEY_SID=SK3e73486edc45102f03ab49f2ea2a5482
TWILIO_API_KEY_SECRET=EeONR61VZgpL60rcXU9cRyJjhT78iq0v
TWILIO_TWIML_APP_SID=APc8ee4760f01cbb73803a2596ab48b607

# DeepSeek — LLM (chat completions + embeddings RAG). Remplace OpenAI entièrement.
# Même politique que les clés Twilio ci-dessus : gérée ici faute d'accès Vercel Dashboard.
DEEPSEEK_API_KEY=sk-eecdb292d8814e9686421be3db312ecf

# MiniMax — TTS voix pour le web (preview) et l'agent Fly.io (vrais appels).
MINIMAX_API_KEY=sk-api-0ZUVKEMWd9H2LtkLTxJ_vtx6mWuq576AWCWEArVZz5-niTl0rcOCGGI3OGO8KMjahxuJ9kap8klJV8zGb-hWzvIl9mad5rsjn_efhDmLgR5V3Ux_Sr7V9Z4
