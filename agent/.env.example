# LiveKit Cloud (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# MiniMax — TTS (and optional voice clone)
MINIMAX_API_KEY=
# Optional overrides
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Optional: cloned/preset MiniMax voice id (see agent/clone_voice.py)
MINIMAX_VOICE_ID=
MINIMAX_TTS_MODEL=
MINIMAX_TTS_EMOTION=

# DeepSeek — LLM brain (deepseek-chat by default, OpenAI-compatible API)
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # override for proxy / on-prem

# OpenAI — RAG embeddings only (text-embedding-3-small, 1536 dims).
# Not needed if RAG is disabled on all agents.
OPENAI_API_KEY=

# Deepgram STT (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# n8n integration (Settings -> API in your n8n instance)
N8N_BASE_URL=https://your-n8n.example.cloud
N8N_API_KEY=
# Optional: defaults to ${N8N_BASE_URL}/webhook
N8N_WEBHOOK_BASE_URL=

# Supabase — shared with the front-end. Service role for full access (RLS bypassed).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set LLM_PROVIDER=openai (uses OPENAI_API_KEY) or LLM_PROVIDER=anthropic.
# Default is deepseek — no override needed.
LLM_PROVIDER=deepseek
ANTHROPIC_API_KEY=

# Human-first inbound routing (off by default — set to 1 to activate).
# When enabled AND human agents are assigned to a phone number via Team → Numéros,
# inbound calls ring those agents first (via Mon poste / Softphone) for up to
# HUMAN_FIRST_WAIT_SECS seconds before Charlotte takes over.
# Also requires: manager assigns human users to the number under Team > member > Numbers.
HUMAN_FIRST_INBOUND=0
# HUMAN_FIRST_WAIT_SECS=18
