# LiveKit Cloud (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# MiniMax (https://platform.minimax.io)
MINIMAX_API_KEY=
# Optional overrides
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2

# Optional: cloned/preset MiniMax voice id (see agent/clone_voice.py)
MINIMAX_VOICE_ID=
MINIMAX_TTS_MODEL=
MINIMAX_TTS_EMOTION=

# Deepgram STT (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# n8n integration (Settings -> API in your n8n instance)
N8N_BASE_URL=https://your-n8n.example.cloud
N8N_API_KEY=
# Optional: defaults to ${N8N_BASE_URL}/webhook
N8N_WEBHOOK_BASE_URL=
