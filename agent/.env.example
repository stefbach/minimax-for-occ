# LiveKit Cloud (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# MiniMax — TTS (and optional voice clone)
MINIMAX_API_KEY=
# Optional overrides
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Optional: cloned/preset MiniMax voice id (see agent/clone_voice.py)
MINIMAX_VOICE_ID=
MINIMAX_TTS_MODEL=
MINIMAX_TTS_EMOTION=

# OpenAI — LLM brain (gpt-4o-mini by default)
OPENAI_API_KEY=
# Optional overrides
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # leave unset for api.openai.com

# Deepgram STT (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# n8n integration (Settings -> API in your n8n instance)
N8N_BASE_URL=https://your-n8n.example.cloud
N8N_API_KEY=
# Optional: defaults to ${N8N_BASE_URL}/webhook
N8N_WEBHOOK_BASE_URL=

# Supabase — shared with the front-end. Service role for full access (RLS bypassed).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional brain provider override (used when no agent_id is provided)
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
